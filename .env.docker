# ══════════════════════════════════════════════════════════════════
#  TransportOS — Docker Environment File
#  Copy this to .env  and fill in your secrets before running:
#    cp .env.docker .env
#
#  Then start everything with:
#    docker compose --env-file .env up --build -d
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=logistics
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=logistics

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_USER=logistics
MONGO_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────
# Generate a new one: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_EXPIRES=8h

# ── AI Keys (optional — services run in demo mode without these) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Stripe — Finance (optional) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications (optional — console logs in demo mode) ──────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@transportos.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
