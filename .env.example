# ================================================================
# TransportOS — Environment Variables
# Copy this file → .env  and fill in your values
# ================================================================

# ── PostgreSQL (install locally: https://postgresql.org/download)
POSTGRES_USER=logistics
POSTGRES_PASSWORD=Rojamary2026&
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=logistics
DATABASE_URL=postgresql://logistics:secret@127.0.0.1:5432/logistics

# ── MongoDB (install locally: https://www.mongodb.com/try/download/community)
MONGO_USER=logistics
MONGO_PASSWORD=Rojamary2026&
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_URL=mongodb://127.0.0.1:27017/tracking

# ── Redis (install locally: https://redis.io/download)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=Rojamary2026&
REDIS_URL=redis://127.0.0.1:6379

# ── Mosquitto MQTT (install: https://mosquitto.org/download)
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USER=
MQTT_PASS=

# ── Auth
JWT_SECRET=bd681ff1b19683de989a3947a24702b4f075eeaf1944e04054dc291cf565ce6c5f15e5994dc257d686d5800db5266952ef2692a1839f2e16b3649210ebb09a80
JWT_EXPIRES=8h

# ── AI Keys (optional — AI chat works without these in demo mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Stripe — Finance (optional, demo mode works without)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Notifications (optional — console logs in demo mode)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@transportos.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Service ports (change if a port is already taken on your machine)
PORT_GATEWAY=4000
PORT_ERP=4001
PORT_TRANSPORT=4002
PORT_TRACKING=4003
PORT_IDENTITY=4005
PORT_FINANCE=4006
PORT_ORDERS=4007
PORT_NOTIFY=4008
PORT_INTEGRATE=4009
PORT_ANALYTICS=4010
PORT_AI=8001

# ── Frontend
VITE_API_GATEWAY=http://localhost:4000
VITE_WS_TRACKING=http://localhost:4003

# ── App
NODE_ENV=development
LOG_LEVEL=info
